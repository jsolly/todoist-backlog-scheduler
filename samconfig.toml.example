version = 0.1

[default.global.parameters]
stack_name = "todoist-backlog-scheduler"
region = "us-east-1"

[default.build.parameters]
template_file = "aws/template.yaml"
# CodeUri paths in the template are relative to repo root so `sam build` can find
# the shared src/ modules and the root package.json / node_modules.
base_dir = "."

[default.deploy.parameters]
capabilities = "CAPABILITY_IAM"
resolve_s3 = true
confirm_changeset = true
# Personal-deploy default; template's `Default: 0` (no limit) remains for non-default callers.
parameter_overrides = "MaxTasksPerDay=5 AlertTopicArn=/shared-infra/alert-topic-arn TodoistApiKey=your-todoist-api-key"

# Copy to samconfig.toml (gitignored). Local credentials: export AWS_PROFILE in shell or .env.local.
# Cursor cloud: CURSOR_AWS_ASSUME_IAM_ROLE_ARN + SAMCONFIG_TOML secret (no profile=). See docs/cloud-agents.md.
