#!/usr/bin/env bash
# Pre-push gate for todoist-backlog-scheduler.
#
# Thin shim over the shared fleet gate library (dotagents/gate/gate-lib.sh): the
# ~100 lines of shared boilerplate — push-ref parsing, the gitleaks secrets scan,
# markdown-lint-on-change, the doc-only fast path, and run_step (silent on green,
# full output on red) — live in the lib. This file declares only the quality
# steps. Gate-only: todoist's CI workflow never deployed; the SAM deploy stays a
# manual local step (`npm run deploy:infra`), so there is no working-tree guard here.
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"; cd "$ROOT"
# shellcheck source=/dev/null
source "${DOTAGENTS_GATE_LIB:-$HOME/code/dotagents/gate/gate-lib.sh}" || {
  echo "✗ dotagents gate-lib not found (expected ~/code/dotagents/gate/gate-lib.sh) — re-run install-local-agent-runtime.sh." >&2
  exit 1
}

gate_begin "todoist-backlog-scheduler"   # parse push; gitleaks; md-lint; doc-only fast path; banner; ERR trap

gate_require_node                         # enforce the pinned Node (.nvmrc), not whatever's on PATH
# Resolve sam to the repo-pinned version (.mise.toml) — non-interactive hook, so the shell profile's
# mise activation isn't loaded. Guarded; degrades to global sam without mise (rules/tool-versions.md).
command -v mise >/dev/null 2>&1 && eval "$(mise activate bash --shims)"
gate_require_cli sam                       # the sam validate step needs the SAM CLI (system tool, not an npm dep)

# --- Quality gate (run_step: silent on green, full output + abort on red) ---
run_step "dep grounding" gate_check_dep_grounding .git-hooks/pre-push scripts/*.sh aws/*.sh
run_step "biome ci"  npx --no-install biome ci . --error-on-warnings
run_step "yaml lint" npm run check:yaml
run_step "tsc"       npm run check:ts
run_step "vitest"    npm test
run_step "sam validate" sam validate --lint -t aws/template.yaml
# Build the Lambda bundle too — `sam validate` checks template syntax only, never that the
# handler code esbuild-bundles, so a bundling regression would otherwise first surface at
# `npm run deploy:infra`. Pass -t/--base-dir EXPLICITLY (not a bare `sam build`): samconfig.toml is
# gitignored and holds a deploy secret in parameter_overrides, so the gate builds from TRACKED
# files only and never depends on it being present. (`.worktreeinclude` does carry samconfig into
# worktrees for the manual `npm run deploy:code` path, but a worktree that skipped provisioning
# wouldn't have it — and this gate, which runs in a worktree, must still pass.) `-t
# aws/template.yaml --base-dir .` mirrors samconfig's [build.parameters] (CodeUri is repo-root-
# relative). esbuild BuildMethod → no Docker; gate_require_cli sam is the precond.
run_step "sam build" gate_sam_build -t aws/template.yaml --base-dir .

echo "✓ pre-push gate complete  (deploy is manual: npm run deploy:infra)"
