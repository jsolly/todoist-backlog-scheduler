# `npm ci` installs the committed lockfile deterministically, so the audit summary
# ("N vulnerabilities") and funding plug ("N packages looking for funding") are pure
# noise on the deploy path (aws/deploy.sh + aws/deploy-code.sh run a bare `npm ci` at
# repo root). Advisories are tracked out-of-band (Dependabot is off fleet-wide) and these
# are build-tooling-only deps (esbuild + SAM bundler), never in the Lambda runtime.
# `npm audit` still works on demand.
audit=false
fund=false
